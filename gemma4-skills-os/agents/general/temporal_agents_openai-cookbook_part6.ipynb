    "        \"type\": \"string\",\n",
    "        \"format\": \"date\",\n",
    "        \"description\": \"The start (inclusive) of the date range to filter knowledge-graph facts.\"\n",
    "      },\n",
    "      \"end_date_range\": {\n",
    "        \"type\": \"string\",\n",
    "        \"format\": \"date\",\n",
    "        \"description\": \"The end (inclusive) of the date range to filter knowledge-graph facts.\"\n",
    "      },\n",
    "      \"topic_filter\": {\n",
    "        \"type\": \"array\",\n",
    "        \"items\": {\n",
