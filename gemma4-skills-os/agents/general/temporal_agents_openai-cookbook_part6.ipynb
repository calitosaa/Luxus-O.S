    "      }\n",
    "    },\n",
    "    \"required\": [\n",
    "      \"question\",\n",
    "      \"companies\",\n",
    "      \"start_date_range\",\n",
    "      \"end_date_range\",\n",
    "      \"topic_filter\"\n",
    "    ],\n",
    "    \"additionalProperties\": False\n",
    "  }\n",
    "}"
