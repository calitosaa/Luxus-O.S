---

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ECC Install Profiles",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1
          },
          "modules": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$"
            }
          }
        },
        "required": [
          "description",
          "modules"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "version",
    "profiles"
  ],
  "additionalProperties": false
}
