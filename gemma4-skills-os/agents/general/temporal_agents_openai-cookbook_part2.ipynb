    "      \"value\": \"10%\",\n",
    "    }\n",
    "  ],\n",
    "  \"entities\": [\n",
    "    {\n",
    "      \"entity_idx\": 0,\n",
    "      \"name\": \"Google\",\n",
    "      \"type\": \"Organization\",\n",
    "      \"description\": \"Technology Company\",\n",
    "    },\n",
    "    {\n",
    "      \"entity_idx\": 1,\n",
    "      \"name\": \"Revenue\",\n",
    "      \"type\": \"Financial Metric\",\n",
    "      \"description\": \"Income of a Company\",\n",
    "    }\n",
    "  ]\n",
    "}\n",
    "\n",
    "Example 2 Statement: \"Amazon developed a new AI chip in 2024.\"\n",
    "Example 2 Output:\n",
    "{\n",
    "  \"triplets\": [\n",
    "    {\n",
    "      \"subject_name\": \"Amazon\",\n",
    "      \"subject_id\": 0,\n",
    "      \"predicate\": \"DEVELOPED\",\n",
    "      \"object_name\": \"AI chip\",\n",
    "      \"object_id\": 1,\n",
    "      \"value\": None,\n",
    "    },\n",
    "  ],\n",
    "  \"entities\": [\n",
    "    {\n",
    "      \"entity_idx\": 0,\n",
    "      \"name\": \"Amazon\",\n",
    "      \"type\": \"Organization\",\n",
    "      \"description\": \"E-commerce and cloud computing company\"\n",
    "    },\n",
    "    {\n",
    "      \"entity_idx\": 1,\n",
    "      \"name\": \"AI chip\",\n",
    "      \"type\": \"Technology\",\n",
    "      \"description\": \"Artificial intelligence accelerator hardware\"\n",
    "    }\n",
    "  ]\n",
    "}\n",
    "\n",
    "Example 3 Statement: \"It is expected that TechNova Inc will launch its AI-driven product line in Q3 2025.\",\n",
    "Example 3 Output:{\n",
    "  \"triplets\": [\n",
