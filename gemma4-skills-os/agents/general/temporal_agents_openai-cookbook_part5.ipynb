   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 4.1.2. (Re-)Initialise OpenAI Client"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
