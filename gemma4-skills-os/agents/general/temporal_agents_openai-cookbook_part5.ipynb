   "source": [
    "### 4.1.3. (Re-)Load our Temporal Knowledge Graph"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from cb_functions import build_graph, load_db_from_hf\n",
    "\n",
    "conn = load_db_from_hf()\n",
    "G = build_graph(conn)\n",
