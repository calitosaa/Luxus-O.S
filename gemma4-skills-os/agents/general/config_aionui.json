---
source_repo: https://github.com/iOfficeAI/AionUi
source_file: .gemini/config.json
license: MIT
category: agents/general
imported_at: 2026-04-19
---

{
  "$schema": "https://developers.google.com/gemini-code-assist/docs/config-schema",
  "codeReview": {
    "enabled": true,
    "autoReview": true,
    "maxFilesToReview": 50,
    "excludePatterns": [
      "**/*.min.js",
      "**/*.min.css",
      "**/dist/**",
      "**/build/**",
      "**/node_modules/**",
      "**/*.lock",
      "**/package-lock.json",
      "**/bun.lockb"
    ]
  },
  "pullRequestSummary": {
    "enabled": true,
    "includeStats": true
  }
}
