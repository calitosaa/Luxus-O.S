{
  "connectionPool": {
    "min": 2,
    "max": 10,
    "idleTimeout": 30000
  },
  "writeBatch": {
    "size": 50,
    "flushInterval": 1000
  },
  "readCache": {
    "maxSize": 1000,
    "ttl": 60000
  },
  "compression": {
    "enabled": true,
    "threshold": 1024
  }
}