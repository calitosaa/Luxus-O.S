ion\"]) for q in eval_data]\ngrades = [grade_completion(output, a[\"golden_answer\"]) for output, a in zip(outputs, eval_data)]\nprint(f\"Score: {grades.count('correct') / len(grades) * 100}%\")\n\n```\n",
