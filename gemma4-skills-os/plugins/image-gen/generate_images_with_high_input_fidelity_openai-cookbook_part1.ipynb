   ],
   "source": [
    "edit_input_path = \"imgs/desk.png\"\n",
    "edit_input_img = open(edit_input_path, \"rb\")\n",
    "display(IPImage(edit_input_path))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "478cf5cc",
   "metadata": {},
   "source": [
    "### Item edit"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "8451736c",
   "metadata": {},
   "outputs": [],
   "source": [
    "edit_prompt = \"Make the mug olive green\"\n",
    "edit_result = edit_img(edit_input_img, edit_prompt)"
   ]
  },
