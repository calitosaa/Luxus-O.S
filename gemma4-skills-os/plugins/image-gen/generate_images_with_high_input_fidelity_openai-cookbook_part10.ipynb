    "# utility function to convert to bytes\n",
    "def pil_to_bytes(img, fmt=\"PNG\"):\n",
    "    buf = io.BytesIO()\n",
    "    img.save(buf, format=fmt)\n",
    "    buf.seek(0)\n",
    "    return buf\n",
    "\n",
